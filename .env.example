# Futuri Deal Calculator - Environment Variables
# Copy this file to .env.local for local development
# For production, set these in the Vercel dashboard: Settings > Environment Variables

# Anthropic API Key (required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: Override default model (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Override default max tokens (defaults to 4096)
# ANTHROPIC_MAX_TOKENS=4096
